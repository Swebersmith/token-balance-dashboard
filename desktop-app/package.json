{
  "name": "token-balance-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Private Windows desktop dashboard for AI provider balances.",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "powershell -ExecutionPolicy Bypass -File scripts/make-portable.ps1",
    "dist:builder": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "io.tokenbalance.desktop",
    "productName": "Token Balance",
    "files": ["main.cjs", "preload.cjs", "renderer/**/*", "package.json"],
    "win": { "target": "portable", "signAndEditExecutable": false }
  }
}
